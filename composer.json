{
  "name": "websolidaria/boilerplate",
  "description": "Kirby 5 Boilerplate for Web Solidaria",
  "type": "project",
  "require": {
    "php": "~8.2.0 || ~8.3.0 || ~8.4.0",
    "getkirby/cms": "^5.0",
    "mzur/kirby-uniform": "^5.7",
    "timnarr/kirby-imagex": "^0.1.4",
    "sylvainjule/embed": "^1.2",
    "tobimori/kirby-seo": "^2.0.0-alpha.8",
    "league/oauth2-google": "^4.0"
  },
  "config": {
    "allow-plugins": {
      "getkirby/composer-installer": true
    },
    "optimize-autoloader": true
  },
  "scripts": {
    "start": [
      "Composer\\Config::disableProcessTimeout",
      "@php -S localhost:8000 kirby/router.php"
    ]
  }
}
