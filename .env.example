# Configuración de Cloudflare Turnstile para Apanhem
# Obtén tu clave en: https://dash.cloudflare.com/?to=/:account/turnstile

# Site Key (clave pública)
TURNSTILE_SITE_KEY=tu_site_key_aqui

# Secret Key (clave privada)
TURNSTILE_SECRET_KEY=tu_secret_key_aqui

# Forzar activación en local (true/false)
TURNSTILE_FORCE_ENABLE=false
